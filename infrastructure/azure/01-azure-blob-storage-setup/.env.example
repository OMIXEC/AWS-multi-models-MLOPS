# Azure Authentication (Service Principal - Recommended for automation)
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret

# Azure Resource Configuration
AZURE_RESOURCE_GROUP=rg-mlops
AZURE_LOCATION=eastus

# Azure Storage Configuration
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_CONTAINER_NAME=models

# Alternative: Use Connection String (for simpler local development)
# Get this from Azure Portal > Storage Account > Access keys
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...
