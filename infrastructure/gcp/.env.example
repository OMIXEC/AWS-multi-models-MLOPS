# GCP Project
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# Storage
GCS_BUCKET_NAME=mlops-multi-models-gcp

# Auth — set if NOT using `gcloud auth application-default login`
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Artifact Registry & Cloud Run
GAR_REPOSITORY_NAME=mlops-repo
CLOUD_RUN_SERVICE=mlops-api

# Compute
GCE_INSTANCE_NAME=mlops-prod
